# Копировать в `.development.env` и заполнить
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# PostgreSQL (docker-compose → порт 5433)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/90games?schema=public

# Redis (docker-compose → порт 6380)
REDIS_URL=redis://localhost:6380

# JWT — сменить на рандомный 64+ байта для прода
JWT_SECRET=dev-secret-change-me
JWT_TTL_SECONDS=2592000

# OpenRouter — M8+
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Rate limits
RATE_LIMIT_CHAT_PER_MIN=30
RATE_LIMIT_CHAT_IP_PER_MIN=120

# Device id hashing — сменить для прода
DEVICE_ID_SALT=dev-salt-change-me
