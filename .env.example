# Переменные для docker-compose (корневой). Скопировать в `.env` и заполнить.

# ───── PostgreSQL ─────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=90games
POSTGRES_PORT=5433

# ───── Redis ─────
REDIS_PORT=6380

# ───── Server (NestJS) ─────
SERVER_PORT=3000
JWT_SECRET=change-me-to-long-random-64bytes
JWT_TTL_SECONDS=2592000
DEVICE_ID_SALT=change-me-to-random-salt
LOG_LEVEL=info

# OpenRouter (необязательно до M8)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Rate limits
RATE_LIMIT_CHAT_PER_MIN=30
RATE_LIMIT_CHAT_IP_PER_MIN=120

# CORS whitelist — csv-список Origin-ов web-клиента (для production обязательно).
# Пусто = любые Origin-ы (dev). Пример:
#   ALLOWED_ORIGINS=https://app.babyfunner.ru,http://localhost:8080
ALLOWED_ORIGINS=

# ───── TTS (Silero нейросетевое озвучивание) ─────
# Полностью выключить нейро-TTS (клиент автоматически упадёт на expo-speech).
# Выставить `false` на слабом VPS, где нет ~1 ГБ RAM под PyTorch.
TTS_ENABLED=true
# URL Python-sidecar'а в docker-network. Не менять без причины.
TTS_WORKER_URL=http://tts-worker:5000
# Потолок размера дискового кеша. При превышении самые старые WAV эвиктятся.
TTS_MAX_CACHE_MB=512
# Дефолтный голос для ребёнка. Варианты: xenia (взрослый жен), kseniya, baya, aidar (муж), eugene (муж).
TTS_DEFAULT_VOICE=xenia
# Таймаут запроса к worker'у. При холодном старте модели первый запрос
# может идти дольше — тюним здесь, если начнёт падать по timeout'у.
TTS_REQUEST_TIMEOUT_MS=15000
# Rate-limit (POST /tts/synthesize) — per-IP, из throttler'а.
TTS_RATE_LIMIT_PER_MIN=60
# Кол-во потоков torch в sidecar'е. Повышаем = быстрее inference, но упирается
# в CPU-квоту контейнера. На 2 vCPU оптимум ≈ 4; на 4 vCPU = 6–8.
TTS_TORCH_THREADS=4
# Уровень логирования sidecar'а (DEBUG/INFO/WARNING/ERROR).
TTS_LOG_LEVEL=INFO

# ───── Web (Expo static) ─────
# Базовый URL API для встраивания в web-бандл на этапе build
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# Режим TTS на клиенте: `server` (Silero, дефолт) или `native` (принудительный
# expo-speech — если sidecar недоступен, хочется быстрого запуска и т.п.).
EXPO_PUBLIC_TTS_MODE=server
WEB_PORT=8080

# ───── Docker image tag ─────
IMAGE_TAG=latest
