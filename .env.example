# Переменные для docker-compose (корневой). Скопировать в `.env` и заполнить.

# ───── PostgreSQL ─────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=90games
POSTGRES_PORT=5433

# ───── Redis ─────
REDIS_PORT=6380

# ───── Server (NestJS) ─────
SERVER_PORT=3000
JWT_SECRET=change-me-to-long-random-64bytes
JWT_TTL_SECONDS=2592000
DEVICE_ID_SALT=change-me-to-random-salt
LOG_LEVEL=info

# OpenRouter (необязательно до M8)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Rate limits
RATE_LIMIT_CHAT_PER_MIN=30
RATE_LIMIT_CHAT_IP_PER_MIN=120

# ───── Web (Expo static) ─────
# Базовый URL API для встраивания в web-бандл на этапе build
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
WEB_PORT=8080

# ───── Docker image tag ─────
IMAGE_TAG=latest
