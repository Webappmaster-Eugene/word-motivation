{
  "name": "ninegames-mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:web": "expo start --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web:export": "expo export --platform web --output-dir dist-web && node -e \"require('fs').copyFileSync('node_modules/canvaskit-wasm/bin/full/canvaskit.wasm', 'dist-web/canvaskit.wasm'); console.log('canvaskit.wasm copied')\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"app/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "prebuild": "expo prebuild --clean"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.0",
    "@shopify/react-native-skia": "1.5.10",
    "@tanstack/react-query": "^5.62.0",
    "@xstate/react": "^5.0.0",
    "expo": "~52.0.20",
    "expo-av": "~15.0.2",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.3",
    "expo-dev-client": "~5.0.6",
    "expo-file-system": "~18.0.4",
    "expo-haptics": "~14.0.0",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.13",
    "expo-secure-store": "~14.0.0",
    "expo-speech": "~13.0.0",
    "expo-speech-recognition": "^2.1.5",
    "expo-splash-screen": "~0.29.18",
    "expo-sqlite": "~15.0.3",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-filament": "^1.9.0",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-web": "~0.19.13",
    "react-native-worklets-core": "^1.3.3",
    "xstate": "^5.19.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "eslint-config-expo": "~8.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.2",
    "prettier": "^3.4.1",
    "react-test-renderer": "18.3.1",
    "typescript": "~5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/tests/setup.ts"
    ],
    "moduleNameMapper": {
      "\\.(glb|gltf|bin|hdr)$": "<rootDir>/tests/__mocks__/asset-mock.ts",
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@app/(.*)$": "<rootDir>/app/$1",
      "^@assets/(.*)$": "<rootDir>/assets/$1",
      "^@shopify/react-native-skia$": "<rootDir>/tests/__mocks__/@shopify/react-native-skia.ts",
      "^react-native-filament$": "<rootDir>/tests/__mocks__/react-native-filament.ts"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@shopify/react-native-skia))"
    ]
  }
}
